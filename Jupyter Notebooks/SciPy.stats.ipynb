   "source": [
    "import scipy.stats as ss\n",
    "import numpy as np\n",
    "\n",
    "a = ss.norm(0,1).rvs((1,2))\n",
    "b = ss.norm(1,1).rvs((1,2))\n",
    "print(a,b)\n",
    "\n",
    "np.concatenate((a,b), axis = 0)\n",
    "np.repeat(0,2)"
   ],
